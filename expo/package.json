{
  "name": "complex-patient",
  "private": true,
  "version": "0.0.1",
  "packageManager": "yarn@4.15.0",
  "main": "expo-router/entry",
  "description": "The Complex Patient – zero-knowledge E2EE health platform",
  "workspaces": [
    "apps/mobile",
    "apps/web",
    "packages/crypto-engine",
    "packages/key-store",
    "packages/local-vault",
    "packages/sync-engine",
    "packages/domain",
    "packages/ui",
    "packages/insights",
    "packages/medications",
    "packages/symptom-journal",
    "packages/clinical-export",
    "packages/weather",
    "packages/med-visuals"
  ],
  "scripts": {
    "eas-build-pre-install": "corepack enable",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "build:web": "EXPO_ROUTER_APP_ROOT=./apps/web/app npx expo export --platform web --output-dir dist/web",
    "start:web": "EXPO_ROUTER_APP_ROOT=./apps/web/app npx expo start --web",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "build:clean": "rm -rf android ios && npx expo prebuild --clean",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "@fast-check/vitest": "^0.1.3",
    "@types/babel__core": "^7",
    "@types/babel__generator": "^7",
    "@types/babel__traverse": "^7",
