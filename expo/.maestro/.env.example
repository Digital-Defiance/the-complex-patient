# Copy to .maestro/.env and fill in for local Maestro runs.
# Or run: yarn maestro:provision  (auto-generates from WordPress Studio via studio wp)
# Never commit .maestro/.env (gitignored).

MAESTRO_WP_USERNAME=maestro-e2e
MAESTRO_WP_PASSWORD=
MAESTRO_VAULT_PASSPHRASE=MaestroTestVaultPhrase2026!
MAESTRO_BIRTH_MONTH=6
MAESTRO_BIRTH_YEAR=1990

# Maestro: max wait for KDF + vault decrypt after unlock submit (ms). Default 300000 (5 min).
# MAESTRO_UNLOCK_TIMEOUT_MS=300000

# Optional overrides for maestro:provision:
# COMPLEX_PATIENT_STUDIO_SITE_PATH=$HOME/Studio/the-complex-patient
# COMPLEX_PATIENT_LOCAL_WP_URL=http://localhost:8881
