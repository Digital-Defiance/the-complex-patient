{
  "name": "complex-patient/sync-plugin",
  "description": "Zero-knowledge blind sync backend WordPress plugin",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": {
      "ComplexPatient\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ComplexPatient\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
